# MiData API-Token
# db.scout.ch -> Abteilung -> API-Token, nur Lesen nötig
MIDATA_TOKEN=dein-api-token-hier
# MIDATA_BASE_URL=https://db.scout.ch

# Gruppe und Filter
GROUP_ID=123
FILTER_ID=456

# Reminder-Tage (kommasepariert, z.B. 7,1 = 7 Tage vorher + 1 Tag vorher)
# REMINDER_DAYS=7,1

# SMTP Relay
# MX-Hostname aus dem Exchange Admin Center:
#   Nachrichtenfluss -> Connectors -> eingehender Connector
SMTP_HOST=example-domain.mail.protection.outlook.com
# SMTP_PORT=25

# Absender – muss eine verifizierte Adresse im Tenant sein
MAIL_FROM=noreply@example.com

# Empfaenger (mehrere mit Komma trennen)
MAIL_TO=empfaenger@example.com

# Optionale Overrides:
# MAIL_SUBJECT_TPL=Geburtstag: {name} hat am {date} Geburtstag!
# FETCH_WORKERS=5
# STATE_FILE=reminder_state.json